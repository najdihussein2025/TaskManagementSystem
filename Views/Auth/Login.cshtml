@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Auth/auth.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <main class="auth-layout">
        <section class="auth-info auth-info-left">
            <div class="auth-info-inner">
                <a href="/" class="brand" aria-label="TaskFlow home">
                    <span class="brand-icon">✓</span>
                    <span class="brand-text">TaskFlow</span>
                </a>
                <div class="info-content">
                    <h1>Welcome back</h1>
                    <p>Sign in to manage your tasks</p>
                    <ul class="feature-list">
                        <li><span class="check-icon">✓</span>Track your tasks in real-time</li>
                        <li><span class="check-icon">✓</span>Collaborate with your team</li>
                        <li><span class="check-icon">✓</span>Stay organized and productive</li>
                    </ul>
                </div>
                <p class="switch-auth">
                    Don&rsquo;t have an account?
                    <a href="/Auth/Register">Register &rarr;</a>
                </p>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-form-wrap">
                <div class="auth-card">
                    <h2>Sign In</h2>
                    <form id="loginForm" class="auth-form" novalidate>
                        <div class="form-group">
                            <label for="loginEmail">Email</label>
                            <input id="loginEmail" name="email" type="email" placeholder="you@example.com" autocomplete="email" />
                            <small class="field-error" data-error-for="loginEmail"></small>
                        </div>

                        <div class="form-group">
                            <label for="loginPassword">Password</label>
                            <div class="password-wrap">
                                <input id="loginPassword" name="password" type="password" placeholder="••••••••" autocomplete="current-password" />
                                <button class="password-toggle" type="button" data-toggle-password="loginPassword" aria-label="Show password">
                                    <span class="eye"></span>
                                </button>
                            </div>
                            <small class="field-error" data-error-for="loginPassword"></small>
                        </div>

                        <div class="meta-row">
                            <a href="#" class="meta-link">Forgot password?</a>
                        </div>

                        <button class="submit-btn" type="submit">
                            <span class="btn-text">Sign In &rarr;</span>
                            <span class="spinner" aria-hidden="true"></span>
                        </button>
                        <p class="success-message" data-success-for="loginForm">Login successful! Redirecting...</p>
                    </form>

                    <div class="divider"><span>or</span></div>
                    <a href="#" class="guest-btn">Continue as Guest</a>
                </div>

                <p class="bottom-link">
                    New to TaskFlow?
                    <a href="/Auth/Register">Create an account &rarr;</a>
                </p>
            </div>
        </section>
    </main>

    <script src="~/js/Auth/auth.js" asp-append-version="true"></script>
</body>
</html>
