@model TaskManagementSystem.DTOs.Auth.LoginDto
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Auth/auth.css" asp-append-version="true" />
    <style>
        .login-error {
            background: rgba(239, 68, 68, 0.12);
            border: 1px solid rgba(239, 68, 68, 0.4);
            color: #ef4444;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .google-btn {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 12px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            color: #fff;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.2s, border-color 0.2s;
        }
        .google-btn:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.3);
        }
    </style>
</head>
<body class="auth-page">
    <main class="auth-layout">
        <section class="auth-info auth-info-left">
            <div class="auth-info-inner">
                <a href="/Home/Index" class="brand" aria-label="TaskFlow home">
                    <span class="brand-icon">✓</span>
                    <span class="brand-text">TaskFlow</span>
                </a>
                <div class="info-content">
                    <h1>Welcome back</h1>
                    <p>Sign in to manage your tasks</p>
                    <ul class="feature-list">
                        <li><span class="check-icon">✓</span>Track your tasks in real-time</li>
                        <li><span class="check-icon">✓</span>Collaborate with your team</li>
                        <li><span class="check-icon">✓</span>Stay organized and productive</li>
                    </ul>
                </div>
                <p class="switch-auth">
                    Don&rsquo;t have an account?
                    <a href="/Auth/Register">Register &rarr;</a>
                </p>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-form-wrap">
                <div class="auth-card">
                    <h2>Sign In</h2>
                    @if (TempData["Success"] is string ts && !string.IsNullOrEmpty(ts))
                    {
                        <p class="success-message" role="status">@ts</p>
                    }
                    <form asp-controller="Auth" asp-action="Login" method="post" class="auth-form" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="field-error"></div>
                        <div class="form-group">
                            <label for="loginEmail">Email</label>
                            <input type="email" name="Email" id="loginEmail" value="@Model?.Email" placeholder="you@example.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="field-error"></span>
                        </div>

                        <div class="form-group">
                            <label for="loginPassword">Password</label>
                            <div class="password-wrap">
                                <input type="password" name="Password" id="loginPassword" placeholder="••••••••" autocomplete="current-password" />
                                <button class="password-toggle" type="button" data-toggle-password="loginPassword" aria-label="Show password">
                                    <span class="eye"></span>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="field-error"></span>
                        </div>

                        <div class="meta-row">
                            <a href="/ForgotPassword" class="meta-link">Forgot password?</a>
                        </div>

                        @if (ViewBag.Error != null)
                        {
                            <div class="login-error">
                                <span>⚠</span> @ViewBag.Error
                            </div>
                        }

                        @if (TempData["LoginRequired"] != null)
                        {
                            <div class="login-error">
                                <span>⚠</span> @TempData["LoginRequired"]
                            </div>
                        }

                        <button class="submit-btn" type="submit">
                            <span class="btn-text">Sign In &rarr;</span>
                            <span class="spinner" aria-hidden="true"></span>
                        </button>
                    </form>

                    <div class="divider"><span>or</span></div>
                    <a href="/auth/google-login" class="google-btn">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            <path fill="none" d="M0 0h48v48H0z"/>
                        </svg>
                        Continue with Google
                    </a>
                </div>

                <p class="bottom-link">
                    New to TaskFlow?
                    <a href="/Auth/Register">Create an account &rarr;</a>
                </p>
            </div>
        </section>
    </main>

    <script src="~/js/Auth/auth.js" asp-append-version="true"></script>
</body>
</html>
