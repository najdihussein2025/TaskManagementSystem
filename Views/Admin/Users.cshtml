@model List<TaskManagementSystem.DTOs.User.UserDto>
@{
    Layout = null;
    ViewData["Title"] = "Manage Users";
    var searchValue = Context.Request.Query["search"].ToString();
    var statusValue = Context.Request.Query["status"].ToString();
    var pageValue = Context.Request.Query["page"].ToString();
    var activePage = int.TryParse(pageValue, out var parsedPage) && parsedPage > 0 ? parsedPage : 1;
    string BuildPageUrl(int page) => Url.Action("Users", "Admin", new { search = searchValue, status = statusValue, page }) ?? "#";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/users.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-wrapper" id="adminWrapper">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-top">
                <div class="logo-wrap"><a class="brand" href="/"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a><p class="panel-label sidebar-text">Admin Panel</p></div>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/Admin/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Dashboard</span></a>
                    <a href="/Admin/Users" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Manage Users</span><span class="nav-badge">@ViewBag.SidebarUserCount</span></a>
                    <a href="/Admin/Tasks" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg><span class="sidebar-text">Manage Tasks</span><span class="nav-badge success">@ViewBag.SidebarTaskCount</span></a>
                    <a href="/Admin/Categories" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M6 7V5h12v2m-1 0v12H7V7" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Categories</span></a>
                    <a href="/Admin/Reports" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5m0 14 6-6 4 4 6-8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg><span class="sidebar-text">Reports</span></a>
                    <div class="sidebar-divider nav-divider"></div>
                    <a href="/Admin/Settings" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm8 4-.9-.3a7.9 7.9 0 0 0-.5-1.3l.5-.8-1.4-1.4-.8.5a7.9 7.9 0 0 0-1.3-.5L15 4h-2l-.3.9a7.9 7.9 0 0 0-1.3.5l-.8-.5-1.4 1.4.5.8a7.9 7.9 0 0 0-.5 1.3L4 10v2l.9.3c.1.5.3.9.5 1.3l-.5.8 1.4 1.4.8-.5c.4.2.8.4 1.3.5L10 20h2l.3-.9c.5-.1.9-.3 1.3-.5l.8.5 1.4-1.4-.5-.8c.2-.4.4-.8.5-1.3l.9-.3v-2Z" stroke="currentColor" stroke-width="1.5"/></svg><span class="sidebar-text">Settings</span></a>
                </nav>
            </div>
            <div class="sidebar-bottom"><div class="profile-card"><div class="avatar">A</div><div class="profile-info sidebar-text"><strong>Admin User</strong><span>admin@taskflow.com</span></div><a class="logout-btn" href="/Auth/Logout"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8"/></svg></a></div></div>
            <button class="collapse-btn" id="collapseSidebar" type="button" aria-label="Toggle sidebar">❮</button>
        </aside>
        <section class="admin-main">
            <header class="topbar">
                <div><h1>Manage Users</h1><p id="todayDate"></p></div>
                <div class="topbar-actions"><button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button><div class="dropdown-wrap"><button class="avatar-btn" id="avatarBtn" type="button">A</button><div class="dropdown-menu profile-menu" id="profileMenu"><a href="/Admin/Settings">My Profile</a><a href="/Auth/Logout">Logout</a></div></div></div>
            </header>

            <div class="page-content users-page">
                <section class="page-head">
                    <div><h2>Manage Users</h2><p>Manage all registered users</p></div>
                    <button class="btn-primary action-main" id="openAddUser">+ Add User</button>
                </section>

                <form class="card filter-card" id="usersFilterForm" method="get" action="/Admin/Users">
                    <input id="userSearch" name="search" type="text" placeholder="Search by name or email..." value="@searchValue" />
                    <select id="statusFilter" name="status">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(statusValue))">All Status</option>
                        <option value="Active" selected="@(statusValue == "Active")">Active</option>
                        <option value="Inactive" selected="@(statusValue == "Inactive")">Inactive</option>
                    </select>
                </form>

                <section class="card table-card">
                    <div class="table-wrap">
                        <table id="usersTable">
                            <thead><tr><th>Avatar+Name</th><th>Email</th><th>Tasks</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="7" style="text-align:center; color: var(--text-muted);">No users found.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var user in Model)
                                    {
                                        var name = string.IsNullOrWhiteSpace(user.FullName) ? "Unknown User" : user.FullName;
                                        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                        var initials = parts.Length switch
                                        {
                                            0 => "U",
                                            1 => parts[0][0].ToString().ToUpper(),
                                            _ => $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}"
                                        };
                                        var statusClass = user.IsActive ? "active" : "inactive";
                                        var statusText = user.IsActive ? "Active" : "Inactive";
                                        var joinedText = user.CreatedAt == default ? "-" : user.CreatedAt.ToString("dd MMM yyyy");
                                        <tr data-id="@user.Id" data-name="@name" data-email="@user.Email" data-status="@statusText">
                                            <td><span class="row-user"><span class="tiny-avatar c1">@initials</span>@name</span></td>
                                            <td>@user.Email</td>
                                            <td>0</td>
                                            <td><span class="pill @statusClass">@statusText</span></td>
                                            <td>@joinedText</td>
                                            <td>
                                                <button class="action-btn edit-user">Edit</button>
                                                <form method="post" action="/Admin/DeleteUser" style="display:inline;" onsubmit="return confirm('Delete this user?');">
                                                    <input type="hidden" name="id" value="@user.Id" />
                                                    <button class="action-btn delete-user" type="submit">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="pagination">
                        <a href="@BuildPageUrl(Math.Max(1, activePage - 1))">Previous</a>
                        <a class="@(activePage == 1 ? "active" : string.Empty)" href="@BuildPageUrl(1)">1</a>
                        <a class="@(activePage == 2 ? "active" : string.Empty)" href="@BuildPageUrl(2)">2</a>
                        <a class="@(activePage == 3 ? "active" : string.Empty)" href="@BuildPageUrl(3)">3</a>
                        <a href="@BuildPageUrl(activePage + 1)">Next</a>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <div class="modal-overlay" id="userModalOverlay">
        <div class="modal-card">
            <h3 id="userModalTitle">Add New User</h3>
            <form id="userForm" method="post" action="/Admin/CreateUser">
                <input type="hidden" id="userId" name="Id" />
                <label>Full Name<input id="userName" name="FullName" type="text" /></label>
                <label>Email<input id="userEmail" name="Email" type="email" /></label>
                <label class="password-only">Password<input id="userPassword" name="Password" type="password" /></label>
                <label>Role<select id="userRole" name="RoleName"><option>User</option><option>Admin</option></select></label>
                <label>Status<select id="userStatus" name="Status"><option>Active</option><option>Inactive</option></select></label>
                <div class="modal-actions"><button type="button" class="ghost-btn" id="cancelUserModal">Cancel</button><button type="submit" class="btn-primary">Save User</button></div>
            </form>
        </div>
    </div>

    <script src="~/js/Admin/admin.js" asp-append-version="true"></script>
    <script src="~/js/Admin/users.js" asp-append-version="true"></script>
</body>
</html>
