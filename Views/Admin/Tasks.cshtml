</tbody></table></div><div class="pagination"><button>Previous</button><button class="active">1</button><button>2</button><button>Next</button></div></section>
</div></section></div>

<div class="modal-overlay" id="taskFormOverlay"><div class="modal-card wide"><h3 id="taskModalTitle">Create Task</h3><form id="taskForm"><label>Task Title<input id="tTitle" /></label><label>Description<textarea id="tDesc" rows="3"></textarea></label><label>Assign To<select id="tAssign"><option>John Doe</option><option>Sara Miller</option><option>Rami Khalil</option><option>Lara Bou</option><option>Mark Nader</option></select></label><label>Category<select id="tCategory"><option>Design</option><option>Backend</option><option>Frontend</option><option>Docs</option><option>DevOps</option></select></label><label>Priority<select id="tPriority"><option>High</option><option>Medium</option><option>Low</option></select></label><label>Due Date<input id="tDate" type="date" /></label><label>Status<select id="tStatus"><option>Pending</option><option>In Progress</option><option>Completed</option><option>Overdue</option></select></label><div class="modal-actions"><button type="button" class="ghost-btn" id="cancelTaskModal">Cancel</button><button type="submit" class="btn-primary">Save Task</button></div></form></div></div>
<div class="modal-overlay" id="taskDetailOverlay"><div class="modal-card wide"><h3>Task Detail</h3><div class="detail-grid" id="taskDetailBox"></div><div class="modal-actions"><button type="button" class="btn-primary" id="closeTaskDetail">Close</button></div></div></div>

