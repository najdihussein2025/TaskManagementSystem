<section class="admin-main">
<header class="topbar"><div><h1>Manage Tasks</h1><p id="todayDate"></p></div><div class="topbar-actions"><button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button><div class="search-wrap"><input type="text" placeholder="Search tasks..." /></div><div class="dropdown-wrap"><button class="icon-btn" id="notifBtn" type="button"><svg viewBox="0 0 24 24" fill="none"><path d="M15 17h5l-1.4-1.4a2 2 0 0 1-.6-1.4V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 1 1-6 0h6Z" stroke="currentColor" stroke-width="1.8"/></svg><span class="dot-badge">3</span></button><div class="dropdown-menu" id="notifMenu"><p>Task update available.</p><p>Overdue alert generated.</p><p>Deployment notice.</p></div></div><div class="dropdown-wrap"><button class="avatar-btn" id="avatarBtn" type="button">A</button><div class="dropdown-menu profile-menu" id="profileMenu"><a href="#">My Profile</a><a href="/Auth/Login">Logout</a></div></div></div></header>
<div class="page-content tasks-page">
<section class="page-head"><div><h2>Manage Tasks</h2><p>View and manage all system tasks</p></div><button class="btn-primary" id="openTaskModal">+ Create Task</button></section>
<section class="card filter-card"><input id="taskSearch" type="text" placeholder="Search tasks..." /><select id="statusFilter"><option>All Status</option><option>Pending</option><option>In Progress</option><option>Completed</option><option>Overdue</option></select><select id="priorityFilter"><option>All Priority</option><option>High</option><option>Medium</option><option>Low</option></select><select id="categoryFilter"><option>All Categories</option><option>Design</option><option>Backend</option><option>Frontend</option><option>Docs</option><option>DevOps</option></select><select id="userFilter"><option>All Users</option><option>John Doe</option><option>Sara Miller</option><option>Rami Khalil</option><option>Lara Bou</option><option>Mark Nader</option></select><button class="btn-primary" id="applyTaskFilters">Apply Filters</button></section>
<section class="card table-card"><div class="table-wrap"><table id="tasksTable"><thead><tr><th>Task Name</th><th>Assigned To</th><th>Category</th><th>Priority</th><th>Due Date</th><th>Status</th><th>Actions</th></tr></thead><tbody>
<tr data-task="Design login page" data-user="John Doe" data-category="Design" data-priority="High" data-date="Apr 30" data-status="In Progress"><td>Design login page</td><td>John Doe</td><td>Design</td><td class="priority-high">High</td><td>Apr 30</td><td><span class="status in-progress">In Progress</span></td><td><button class="action-btn view-task">View</button><button class="action-btn edit-task">Edit</button><button class="action-btn delete-task">Delete</button><div class="confirm-delete">Confirm? <button class="yes">Yes</button><button class="no">No</button></div></td></tr>
