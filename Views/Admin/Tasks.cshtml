<tr data-task="Connect frontend to API" data-user="John Doe" data-category="Frontend" data-priority="Low" data-date="May 8" data-status="Pending"><td>Connect frontend to API</td><td>John Doe</td><td>Frontend</td><td class="priority-low">Low</td><td>May 8</td><td><span class="status pending">Pending</span></td><td><button class="action-btn view-task">View</button><button class="action-btn edit-task">Edit</button><button class="action-btn delete-task">Delete</button><div class="confirm-delete">Confirm? <button class="yes">Yes</button><button class="no">No</button></div></td></tr>
