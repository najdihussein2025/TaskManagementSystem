<tr data-task="Write API documentation" data-user="Rami Khalil" data-category="Docs" data-priority="Medium" data-date="Apr 28" data-status="Overdue"><td>Write API documentation</td><td>Rami Khalil</td><td>Docs</td><td class="priority-medium">Medium</td><td>Apr 28</td><td><span class="status overdue">Overdue</span></td><td><button class="action-btn view-task">View</button><button class="action-btn edit-task">Edit</button><button class="action-btn delete-task">Delete</button><div class="confirm-delete">Confirm? <button class="yes">Yes</button><button class="no">No</button></div></td></tr>
