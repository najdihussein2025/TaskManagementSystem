@model IEnumerable<TaskManagementSystem.DTOs.Task.TaskDto>
@using TaskManagementSystem.DTOs.Category
@using TaskManagementSystem.DTOs.Task
@using TaskManagementSystem.DTOs.User
@using TaskPriorityEnum = TaskManagementSystem.Enums.TaskPriority
@using TaskStatusEnum = TaskManagementSystem.Enums.TaskStatus
@{
    Layout = null;
    ViewData["Title"] = "Manage Tasks";
    var users = ViewBag.Users as IEnumerable<UserDto> ?? Enumerable.Empty<UserDto>();
    var categories = ViewBag.Categories as IEnumerable<CategoryDto> ?? Enumerable.Empty<CategoryDto>();
    var filter = ViewBag.Filter as TaskFilterDto ?? new TaskFilterDto();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/tasks.css" asp-append-version="true" />
</head>
<body class="admin-body">
<div class="admin-wrapper" id="adminWrapper">
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-top">
            <div class="logo-wrap">
                <a class="brand" href="/">
                    <span class="brand-icon">✓</span>
                    <span class="brand-text sidebar-text">TaskFlow</span>
                </a>
                <p class="panel-label sidebar-text">Admin Panel</p>
            </div>
            <div class="sidebar-divider"></div>
            <nav class="side-nav" id="sideNav">
                <a href="/Admin/Dashboard" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                <a href="/Admin/Users" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Manage Users</span>
                </a>
                <a href="/Admin/Tasks" class="nav-item active">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Manage Tasks</span>
                </a>
                <a href="/Category" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M6 7V5h12v2m-1 0v12H7V7" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Categories</span>
                </a>
                <a href="/Admin/Reports" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5m0 14 6-6 4 4 6-8" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Reports</span>
                </a>
                <div class="sidebar-divider nav-divider"></div>
                <a href="/Admin/Settings" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm8 4-.9-.3a7.9 7.9 0 0 0-.5-1.3l.5-.8-1.4-1.4-.8.5a7.9 7.9 0 0 0-1.3-.5L15 4h-2l-.3.9a7.9 7.9 0 0 0-1.3.5l-.8-.5-1.4 1.4.5.8a7.9 7.9 0 0 0-.5 1.3L4 10v2l.9.3c.1.5.3.9.5 1.3l-.5.8 1.4 1.4.8-.5c.4.2.8.4 1.3.5L10 20h2l.3-.9c.5-.1.9-.3 1.3-.5l.8.5 1.4-1.4-.5-.8c.2-.4.4-.8.5-1.3l.9-.3v-2Z" stroke="currentColor" stroke-width="1.5" /></svg>
                    <span class="sidebar-text">Settings</span>
                </a>
            </nav>
        </div>
        <div class="sidebar-bottom">
            <div class="profile-card">
                <div class="avatar">A</div>
                <div class="profile-info sidebar-text">
                    <strong>Admin User</strong>
                </div>
                <a class="logout-btn" href="/Auth/Login">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" /></svg>
                </a>
            </div>
        </div>
        <button class="collapse-btn" id="collapseSidebar" type="button">❮</button>
    </aside>

    <section class="admin-main">
        <header class="topbar">
            <div>
                <h1>Manage Tasks</h1>
                <p id="todayDate"></p>
            </div>
        </header>

        <div class="page-content tasks-page">
            <section class="page-head">
                <div>
                    <h2>Manage Tasks</h2>
                    <p>View and manage all system tasks</p>
                </div>
                <button class="btn-primary" id="openTaskModal" type="button">+ Create Task</button>
            </section>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-error">@TempData["Error"]</div>
            }

            <section class="card filter-card">
                <form id="taskFilterForm" method="get" action="/Admin/Tasks" style="display: contents;">
                    <input id="taskSearch" name="search" type="text" placeholder="Search tasks..." value="@filter.Search" />
                    <select id="statusFilter" name="status">
                        <option value="">All Status</option>
                        @foreach (TaskStatusEnum status in Enum.GetValues(typeof(TaskStatusEnum)))
                        {
                            <option value="@status" selected="@(string.Equals(filter.Status, status.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@status</option>
                        }
                    </select>
                    <select id="priorityFilter" name="priority">
                        <option value="">All Priority</option>
                        @foreach (TaskPriorityEnum priority in Enum.GetValues(typeof(TaskPriorityEnum)))
                        {
                            <option value="@priority" selected="@(string.Equals(filter.Priority, priority.ToString(), StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@priority</option>
                        }
                    </select>
                    <select id="categoryFilter" name="categoryId">
                        <option value="">All Categories</option>
                        @foreach (var category in categories)
                        {
                            <option value="@category.Id" selected="@(filter.CategoryId == category.Id ? "selected" : null)">@category.Name</option>
                        }
                    </select>
                    <select id="userFilter" name="userId">
                        <option value="">All Users</option>
                        @foreach (var user in users)
                        {
                            <option value="@user.Id" selected="@(filter.UserId == user.Id ? "selected" : null)">@user.FullName</option>
                        }
                    </select>
                    <button class="btn-primary" id="applyTaskFilters" type="submit">Apply Filters</button>
                </form>
            </section>

            <section class="card table-card">
                <div class="table-wrap">
                    <table id="tasksTable">
                        <thead>
                            <tr>
                                <th>Task Name</th>
                                <th>Assigned To</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var task in Model)
                                {
                                    <tr>
                                        <td>@task.Title</td>
                                        <td>@(string.IsNullOrWhiteSpace(task.AssignedToName) ? "Unassigned" : task.AssignedToName)</td>
                                        <td>@(task.CategoryName ?? "-")</td>
                                        <td>@task.Priority</td>
                                        <td>@(task.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                        <td>@task.Status</td>
                                        <td>
                                            <button type="button" class="view-task" data-title="@task.Title" data-description="@task.Description" data-assigned="@task.AssignedToName" data-category="@task.CategoryName" data-priority="@task.Priority" data-status="@task.Status" data-due="@(task.DueDate?.ToString("yyyy-MM-dd"))">View</button>
                                            <button type="button" class="edit-task" data-id="@task.Id">Edit</button>
                                            <form method="post" action="/Admin/DeleteTask/@task.Id" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="delete-task" onclick="return confirm('Delete this task?');">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" style="text-align:center;">No tasks found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </section>
</div>

<div class="modal-overlay" id="taskFormOverlay">
    <div class="modal-card wide">
        <h3 id="taskModalTitle">Create Task</h3>
        <form id="taskForm" method="post" action="/Admin/CreateTask">
            @Html.AntiForgeryToken()
            <label>Task Title<input id="tTitle" name="Title" required /></label>
            <label>Description<textarea id="tDesc" name="Description" rows="3"></textarea></label>
            <label>Assign To
                <select id="tAssign" name="AssignedToUserId">
                    <option value="">Unassigned</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName (@user.Email)</option>
                    }
                </select>
            </label>
            <label>Category
                <select id="tCategory" name="CategoryId">
                    <option value="">Select category</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
            </label>
            <label>Priority
                <select id="tPriority" name="Priority" required>
                    @foreach (TaskPriorityEnum priority in Enum.GetValues(typeof(TaskPriorityEnum)))
                    {
                        <option value="@((int)priority)" selected="@(priority == TaskPriorityEnum.Medium ? "selected" : null)">@priority</option>
                    }
                </select>
            </label>
            <label>Due Date<input id="tDate" name="DueDate" type="date" /></label>
            <label>Status
                <select id="tStatus" name="Status" required>
                    @foreach (TaskStatusEnum status in Enum.GetValues(typeof(TaskStatusEnum)))
                    {
                        <option value="@((int)status)" selected="@(status == TaskStatusEnum.Pending ? "selected" : null)">@status</option>
                    }
                </select>
            </label>
            <div class="modal-actions">
                <button type="button" class="ghost-btn" id="cancelTaskModal">Cancel</button>
                <button type="submit" class="btn-primary">Save Task</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="taskDetailOverlay">
    <div class="modal-card wide">
        <h3>Task Detail</h3>
        <div class="detail-grid" id="taskDetailBox"></div>
        <div class="modal-actions">
            <button type="button" class="btn-primary" id="closeTaskDetail">Close</button>
        </div>
    </div>
</div>

<script src="~/js/Admin/admin.js" asp-append-version="true"></script>
<script src="~/js/Admin/tasks.js" asp-append-version="true"></script>
</body>
</html>
