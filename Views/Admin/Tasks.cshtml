@{
    Layout = null;
    ViewData["Title"] = "Manage Tasks";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/tasks.css" asp-append-version="true" />
</head>
<body class="admin-body">
<div class="admin-wrapper" id="adminWrapper">
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-top">
            <div class="logo-wrap">
                <a class="brand" href="/">
                    <span class="brand-icon">✓</span>
                    <span class="brand-text sidebar-text">TaskFlow</span>
                </a>
                <p class="panel-label sidebar-text">Admin Panel</p>
            </div>
            <div class="sidebar-divider"></div>
            <nav class="side-nav" id="sideNav">
                <a href="/Admin/Dashboard" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Dashboard</span>
                </a>
                <a href="/Admin/Users" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Manage Users</span>
                </a>
                <a href="/Admin/Tasks" class="nav-item active">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Manage Tasks</span>
                </a>
                <a href="/Admin/Categories" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M6 7V5h12v2m-1 0v12H7V7" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Categories</span>
                </a>
                <a href="/Admin/Reports" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5m0 14 6-6 4 4 6-8" stroke="currentColor" stroke-width="1.8" /></svg>
                    <span class="sidebar-text">Reports</span>
                </a>
                <div class="sidebar-divider nav-divider"></div>
                <a href="/Admin/Settings" class="nav-item">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm8 4-.9-.3a7.9 7.9 0 0 0-.5-1.3l.5-.8-1.4-1.4-.8.5a7.9 7.9 0 0 0-1.3-.5L15 4h-2l-.3.9a7.9 7.9 0 0 0-1.3.5l-.8-.5-1.4 1.4.5.8a7.9 7.9 0 0 0-.5 1.3L4 10v2l.9.3c.1.5.3.9.5 1.3l-.5.8 1.4 1.4.8-.5c.4.2.8.4 1.3.5L10 20h2l.3-.9c.5-.1.9-.3 1.3-.5l.8.5 1.4-1.4-.5-.8c.2-.4.4-.8.5-1.3l.9-.3v-2Z" stroke="currentColor" stroke-width="1.5" /></svg>
                    <span class="sidebar-text">Settings</span>
                </a>
            </nav>
        </div>
        <div class="sidebar-bottom">
            <div class="profile-card">
                <div class="avatar">A</div>
                <div class="profile-info sidebar-text">
                    <strong>Admin User</strong>
                </div>
                <a class="logout-btn" href="/Auth/Login">
                    <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" /></svg>
                </a>
            </div>
        </div>
        <button class="collapse-btn" id="collapseSidebar" type="button">❮</button>
    </aside>

    <section class="admin-main">
        <header class="topbar">
            <div>
                <h1>Manage Tasks</h1>
                <p id="todayDate"></p>
            </div>
            <div class="topbar-actions">
                <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                <div class="search-wrap"><input type="text" placeholder="Search tasks..." /></div>
                <div class="dropdown-wrap">
                    <button class="icon-btn" id="notifBtn" type="button">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M15 17h5l-1.4-1.4a2 2 0 0 1-.6-1.4V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 1 1-6 0h6Z" stroke="currentColor" stroke-width="1.8" /></svg>
                    </button>
                    <div class="dropdown-menu" id="notifMenu">
                        <p>No notifications.</p>
                    </div>
                </div>
                <div class="dropdown-wrap">
                    <button class="avatar-btn" id="avatarBtn" type="button">A</button>
                    <div class="dropdown-menu profile-menu" id="profileMenu">
                        <a href="#">My Profile</a>
                        <a href="/Auth/Login">Logout</a>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-content tasks-page">
            <section class="page-head">
                <div>
                    <h2>Manage Tasks</h2>
                    <p>View and manage all system tasks</p>
                </div>
                <button class="btn-primary" id="openTaskModal">+ Create Task</button>
            </section>

            <section class="card filter-card">
                <input id="taskSearch" type="text" placeholder="Search tasks..." />
                <select id="statusFilter">
                    <option>All Status</option>
                </select>
                <select id="priorityFilter">
                    <option>All Priority</option>
                </select>
                <select id="categoryFilter">
                    <option>All Categories</option>
                </select>
                <select id="userFilter">
                    <option>All Users</option>
                </select>
                <button class="btn-primary" id="applyTaskFilters">Apply Filters</button>
            </section>

            <section class="card table-card">
                <div class="table-wrap">
                    <table id="tasksTable">
                        <thead>
                            <tr>
                                <th>Task Name</th>
                                <th>Assigned To</th>
                                <th>Category</th>
                                <th>Priority</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="7">No tasks available.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </section>
</div>

<div class="modal-overlay" id="taskFormOverlay">
    <div class="modal-card wide">
        <h3 id="taskModalTitle">Create Task</h3>
        <form id="taskForm">
            <label>Task Title<input id="tTitle" /></label>
            <label>Description<textarea id="tDesc" rows="3"></textarea></label>
            <label>Assign To
                <select id="tAssign">
                    <option value="">No users available</option>
                </select>
            </label>
            <label>Category
                <select id="tCategory">
                    <option value="">No categories available</option>
                </select>
            </label>
            <label>Priority
                <select id="tPriority">
                    <option value="">Select priority</option>
                </select>
            </label>
            <label>Due Date<input id="tDate" type="date" /></label>
            <label>Status
                <select id="tStatus">
                    <option value="">Select status</option>
                </select>
            </label>
            <div class="modal-actions">
                <button type="button" class="ghost-btn" id="cancelTaskModal">Cancel</button>
                <button type="submit" class="btn-primary">Save Task</button>
            </div>
        </form>
    </div>
</div>

<div class="modal-overlay" id="taskDetailOverlay">
    <div class="modal-card wide">
        <h3>Task Detail</h3>
        <div class="detail-grid" id="taskDetailBox"></div>
        <div class="modal-actions">
            <button type="button" class="btn-primary" id="closeTaskDetail">Close</button>
        </div>
    </div>
</div>

<script src="~/js/Admin/admin.js" asp-append-version="true"></script>
<script src="~/js/Admin/tasks.js" asp-append-version="true"></script>
</body>
</html>
