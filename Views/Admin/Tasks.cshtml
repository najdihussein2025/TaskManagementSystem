<tr data-task="Style dashboard page" data-user="Mark Nader" data-category="Design" data-priority="High" data-date="May 1" data-status="In Progress"><td>Style dashboard page</td><td>Mark Nader</td><td>Design</td><td class="priority-high">High</td><td>May 1</td><td><span class="status in-progress">In Progress</span></td><td><button class="action-btn view-task">View</button><button class="action-btn edit-task">Edit</button><button class="action-btn delete-task">Delete</button><div class="confirm-delete">Confirm? <button class="yes">Yes</button><button class="no">No</button></div></td></tr>
