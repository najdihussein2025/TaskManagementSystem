@model TaskManagementSystem.Dtos.Settings.SettingsDto
@{
    Layout = null;
    ViewData["Title"] = "Settings";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Admin/settings.css" asp-append-version="true" />
</head>
<body class="admin-body">
<div class="admin-wrapper" id="adminWrapper">
    <aside class="admin-sidebar" id="adminSidebar"><div class="sidebar-top"><div class="logo-wrap"><a class="brand" href="/"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a><p class="panel-label sidebar-text">Admin Panel</p></div><div class="sidebar-divider"></div><nav class="side-nav" id="sideNav"><a href="/Admin/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Dashboard</span></a><a href="/Admin/Users" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Manage Users</span><span class="nav-badge">@ViewBag.SidebarUserCount</span></a><a href="/Admin/Tasks" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Manage Tasks</span><span class="nav-badge success">@ViewBag.SidebarTaskCount</span></a><a href="/Admin/Categories" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M4 7h16M6 7V5h12v2m-1 0v12H7V7" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Categories</span><span class="nav-badge">@ViewBag.SidebarCategoryCount</span></a><a href="/Admin/Reports" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M4 19V5m0 14 6-6 4 4 6-8" stroke="currentColor" stroke-width="1.8"/></svg><span class="sidebar-text">Reports</span></a><div class="sidebar-divider nav-divider"></div><a href="/Admin/Settings" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8Zm8 4-.9-.3a7.9 7.9 0 0 0-.5-1.3l.5-.8-1.4-1.4-.8.5a7.9 7.9 0 0 0-1.3-.5L15 4h-2l-.3.9a7.9 7.9 0 0 0-1.3.5l-.8-.5-1.4 1.4.5.8a7.9 7.9 0 0 0-.5 1.3L4 10v2l.9.3c.1.5.3.9.5 1.3l-.5.8 1.4 1.4.8-.5c.4.2.8.4 1.3.5L10 20h2l.3-.9c.5-.1.9-.3 1.3-.5l.8.5 1.4-1.4-.5-.8c.2-.4.4-.8.5-1.3l.9-.3v-2Z" stroke="currentColor" stroke-width="1.5"/></svg><span class="sidebar-text">Settings</span></a></nav></div><div class="sidebar-bottom"><div class="profile-card"><div class="avatar">A</div><div class="profile-info sidebar-text"><strong>Admin User</strong><span>admin@taskflow.com</span></div><a class="logout-btn" href="/Auth/Logout"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8"/></svg></a></div></div><button class="collapse-btn" id="collapseSidebar" type="button">❮</button></aside>
    <section class="admin-main">
        <header class="topbar">
            <div><h1>Settings</h1><p id="todayDate"></p><small id="dirtyNotice">Unsaved changes</small></div>
            <div class="topbar-actions"><button class="btn-primary" id="saveSettings" type="submit" form="settingsForm">Save Changes</button></div>
        </header>
        <div class="page-content settings-page">
            <section class="layout">
                <div class="right-col">
                    <article class="card">
                        <h2>Admin Profile</h2>
                        <div class="profile-big">A</div>
                        <h3>@Model.FullName</h3>
                        <p>@Model.Email</p>
                        <hr />

                        @if (ViewBag.SuccessMessage is string ok && !string.IsNullOrEmpty(ok))
                        {
                            <div class="toast show" style="position:static;transform:none;opacity:1;margin-bottom:10px;">@ok</div>
                        }
                        @if (ViewBag.ErrorMessage is string err && !string.IsNullOrEmpty(err))
                        {
                            <div class="danger-confirm show" style="display:block;margin-bottom:10px;">@err</div>
                        }

                        <form id="settingsForm" asp-controller="Admin" asp-action="Settings" method="post">
                            @Html.AntiForgeryToken()

                            <label>
                                Full Name
                                <input name="FullName" data-dirty value="@Model.FullName" />
                            </label>

                            <label>
                                Email
                                <input value="@Model.Email" readonly />
                            </label>

                            <label>
                                Current Password
                                <div class="pw-wrap">
                                    <input name="CurrentPassword" data-dirty type="password" />
                                    <button type="button" class="pw-toggle">👁</button>
                                </div>
                            </label>

                            <label>
                                New Password
                                <div class="pw-wrap">
                                    <input name="NewPassword" data-dirty type="password" />
                                    <button type="button" class="pw-toggle">👁</button>
                                </div>
                            </label>

                            <label>
                                Confirm Password
                                <div class="pw-wrap">
                                    <input name="ConfirmPassword" data-dirty type="password" />
                                    <button type="button" class="pw-toggle">👁</button>
                                </div>
                            </label>

                            <button class="btn-primary full" type="submit">Update Profile</button>
                        </form>
                    </article>
                </div>
            </section>
        </div>
    </section>
</div>
<div class="toast" id="settingsToast">Settings saved successfully!</div>
<script src="~/js/Admin/admin.js" asp-append-version="true"></script><script src="~/js/Admin/settings.js" asp-append-version="true"></script>
</body>
</html>
