@model TaskManagementSystem.DTOs.Auth.ResetPasswordDto
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Auth/auth.css" asp-append-version="true" />
</head>
<body class="auth-page">
<main class="auth-layout">
    <section class="auth-info auth-info-left">
        <div class="auth-info-inner">
            <a href="/Home/Index" class="brand" aria-label="TaskFlow home">
                <span class="brand-icon">✓</span>
                <span class="brand-text">TaskFlow</span>
            </a>
            <div class="info-content">
                <h1>Create new password</h1>
                <p>Your new password must be at least 6 characters.</p>
                <ul class="feature-list">
                    <li><span class="check-icon">✓</span>Use a strong new password</li>
                    <li><span class="check-icon">✓</span>Do not reuse old passwords</li>
                    <li><span class="check-icon">✓</span>Keep your account secure</li>
                </ul>
            </div>
            <p class="switch-auth">
                Back to sign in?
                <a href="/Auth/Login">Login &rarr;</a>
            </p>
        </div>
    </section>

    <section class="auth-form-panel">
        <div class="auth-form-wrap">
            <div class="auth-card">
                <h2>Reset Password</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="login-error"><span>⚠</span>@ViewBag.Error</div>
                }

                <form method="post" asp-action="ResetPassword" asp-controller="ForgotPassword" class="auth-form" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Email" value="@(ViewBag.Email ?? Model?.Email)" />
                    <input type="hidden" name="OtpCode" value="@(ViewBag.OtpCode ?? Model?.OtpCode)" />

                    <div class="form-group">
                        <label for="newPassword">New Password</label>
                        <input id="newPassword" type="password" name="NewPassword" value="@Model?.NewPassword" placeholder="Min 6 characters" autocomplete="new-password" required />
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <input id="confirmPassword" type="password" name="ConfirmPassword" value="@Model?.ConfirmPassword" placeholder="Repeat new password" autocomplete="new-password" required />
                    </div>
                    <button type="submit" class="submit-btn">
                        <span class="btn-text">Reset Password &rarr;</span>
                        <span class="spinner" aria-hidden="true"></span>
                    </button>
                </form>
            </div>
        </div>
    </section>
</main>
</body>
</html>
