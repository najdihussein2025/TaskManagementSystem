@{
    Layout = null;
    ViewData["Title"] = "My Tasks";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/mytasks.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Dashboard</span></a>
                    <a href="/User/MyTasks" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">My Tasks</span></a>
                    <a href="/User/CreateTask" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">Create Task</span></a>
                    <a href="/User/Profile" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Profile</span></a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg><span class="sidebar-text">Logout</span></a>
                </nav>
            </div>
            <div class="sidebar-bottom"><div class="profile-card"><div class="avatar">JD</div><div class="profile-info sidebar-text"><strong>John Doe</strong><span>john@email.com</span></div></div></div>
            <button class="collapse-btn" id="collapseSidebar" type="button" aria-label="Toggle sidebar">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div><h1>My Tasks</h1><p id="todayDate"></p></div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                    <div class="search-wrap"><input type="text" placeholder="Search tasks..." /></div>
                    <div class="dropdown-wrap"><button class="icon-btn" id="notifBtn" type="button"><svg viewBox="0 0 24 24" fill="none"><path d="M15 17h5l-1.4-1.4a2 2 0 0 1-.6-1.4V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 1 1-6 0h6Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="dot-badge">2</span></button><div class="dropdown-menu" id="notifMenu"><p>Deadline reminder: Design login page.</p><p>JWT auth due soon.</p></div></div>
                    <div class="dropdown-wrap"><button class="avatar-btn" id="avatarBtn" type="button">JD</button><div class="dropdown-menu profile-menu" id="profileMenu"><a href="/User/Profile">My Profile</a><a href="/Auth/Login">Logout</a></div></div>
                </div>
            </header>

            <div class="page-content mytasks-page">
                <section class="page-head">
                    <div><h2>My Tasks</h2><p>All tasks assigned to you</p></div>
                    <a class="btn-primary" href="/User/CreateTask">+ Create New Task</a>
                </section>

                <section class="card filter-card">
                    <input type="text" placeholder="Search my tasks..." />
                    <select><option>All Status</option><option>Pending</option><option>In Progress</option><option>Completed</option><option>Overdue</option></select>
                    <select><option>All Priority</option><option>High</option><option>Medium</option><option>Low</option></select>
                    <select><option>All Categories</option><option>Design</option><option>Backend</option><option>Frontend</option><option>Docs</option></select>
                    <button class="btn-primary" type="button">Filter</button>
                </section>

                <section class="task-grid">
                    <article class="card task-card">
                        <div class="task-top">
                            <span class="pill">Design</span>
                            <span class="pill">High</span>
                        </div>
                        <h3>Design login page</h3>
                        <p>Task in Design category</p>
                        <div class="task-divider"></div>
                        <div class="task-meta">
                            <span class="task-date">Due: Apr 30</span>
                            <span class="status">In Progress</span>
                        </div>
                        <p class="comment-preview">Open task details to manage status and comments.</p>
                        <button class="details-link" type="button">View Details</button>
                    </article>
                </section>

                <section class="pagination-row">
                    <button type="button">Previous</button>
                    <button class="active" type="button">1</button>
                    <button type="button">2</button>
                    <button type="button">Next</button>
                </section>
            </div>
        </section>
    </div>

    <div class="modal-overlay" id="taskDetailOverlay">
        <div class="modal-card">
            <div class="modal-header">
                <h3>Design login page</h3>
                <div class="modal-top"><span class="status in-progress">In Progress</span><span class="pill high">High</span></div>
            </div>
            <div class="modal-content">
                <div class="task-divider"></div>
                <div class="detail-grid">
                    <strong>Category</strong><span>Design</span>
                    <strong>Due Date</strong><span>Apr 30</span>
                    <strong>Description</strong><span>UI design for auth screens with clear states for validation and feedback.</span>
                    <strong>Assigned By</strong><span>Admin User</span>
                </div>
                <form class="status-form" method="post" action="/User/UpdateTaskStatus">
                    <input type="hidden" name="taskId" value="1" />
                    <label for="taskStatus">Status</label>
                    <select id="taskStatus" name="status">
                        <option value="Pending">Pending</option>
                        <option value="In Progress" selected>In Progress</option>
                        <option value="Completed">Completed</option>
                    </select>
                    <button class="btn-primary modal-submit-btn" type="submit">Save Status</button>
                </form>
                <section class="comments-section">
                    <h4>Comments / Notes</h4>
                    <div class="comments-list" id="commentsList">
                        <article class="comment-item">
                            <div class="comment-avatar">AU</div>
                            <div class="comment-body">
                                <div class="comment-head">
                                    <strong>Admin User</strong>
                                    <small>Apr 28, 10:32 AM</small>
                                </div>
                                <p>Please finish this task before deadline.</p>
                            </div>
                        </article>
                        <article class="comment-item">
                            <div class="comment-avatar">JD</div>
                            <div class="comment-body">
                                <div class="comment-head">
                                    <strong>John Doe</strong>
                                    <small>Apr 29, 2:15 PM</small>
                                </div>
                                <p>Frontend completed, waiting API.</p>
                            </div>
                        </article>
                    </div>
                    <div class="comment-input-wrap">
                        <textarea id="commentInput" rows="3" placeholder="Write a comment or note..."></textarea>
                        <div class="comment-actions">
                            <button class="btn-primary" id="addCommentBtn" type="button">Add Comment</button>
                            <button class="btn-ghost" id="clearCommentBtn" type="button">Clear</button>
                        </div>
                    </div>
                </section>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost modal-close-btn" id="closeTaskDetail" type="button">Close</button>
            </div>
        </div>
    </div>

    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script src="~/js/User/mytasks.js" asp-append-version="true"></script>
</body>
</html>
