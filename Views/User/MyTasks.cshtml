@model IEnumerable<TaskManagementSystem.DTOs.Task.TaskDto>
@{
    Layout = null;
    ViewData["Title"] = "My Tasks";

    var tasks = Model?.ToList() ?? new List<TaskManagementSystem.DTOs.Task.TaskDto>();
    var categories = ViewBag.Categories as List<TaskManagementSystem.DTOs.Category.CategoryDto> ?? new List<TaskManagementSystem.DTOs.Category.CategoryDto>();
    var filter = ViewBag.Filter as TaskManagementSystem.DTOs.Task.TaskFilterDto ?? new TaskManagementSystem.DTOs.Task.TaskFilterDto();

    var userName = ViewBag.UserName ?? "User";
    var userInitials = string.IsNullOrEmpty(userName) ? "U" :
        (userName.Split(' ').Length > 1 ?
         $"{userName.Split(' ')[0][0]}{userName.Split(' ')[1][0]}" :
         userName.Substring(0, 2).ToUpper());
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/mytasks.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg>
                        <span class="sidebar-text">Dashboard</span>
                    </a>
                    <a href="/User/MyTasks" class="nav-item active">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                        <span class="sidebar-text">My Tasks</span>
                    </a>
                    <a href="/User/CreateTask" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                        <span class="sidebar-text">Create Task</span>
                    </a>
                    <a href="/User/Profile" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg>
                        <span class="sidebar-text">Profile</span>
                    </a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Logout" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        <span class="sidebar-text">Logout</span>
                    </a>
                </nav>
            </div>
            <div class="sidebar-bottom">
                <div class="profile-card">
                    <div class="avatar">@userInitials</div>
                    <div class="profile-info sidebar-text">
                        <strong>@userName</strong>
                        <span>@User.Identity?.Name</span>
                    </div>
                </div>
            </div>
            <button class="collapse-btn" id="collapseSidebar" type="button">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div><h1>My Tasks</h1><p id="todayDate"></p></div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                    <div class="dropdown-wrap">
                        <button class="avatar-btn" id="avatarBtn" type="button">@userInitials</button>
                        <div class="dropdown-menu profile-menu" id="profileMenu">
                            <a href="/User/Profile">My Profile</a>
                            <a href="/Auth/Logout">Logout</a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="page-content mytasks-page">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success" style="background:rgba(34,197,94,0.1); border:1px solid #22c55e; padding:10px; border-radius:8px; margin-bottom:15px; color:#22c55e;">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-error" style="background:rgba(239,68,68,0.1); border:1px solid #ef4444; padding:10px; border-radius:8px; margin-bottom:15px; color:#ef4444;">
                        @TempData["Error"]
                    </div>
                }

                <section class="page-head">
                    <div>
                        <h2>My Tasks</h2>
                        <p>All tasks assigned to you</p>
                    </div>
                    <a class="btn-primary" href="/User/CreateTask">+ Create New Task</a>
                </section>

                <!-- Filter Section -->
                <section class="filter-card">
                    <form method="get" action="/User/MyTasks">
                        <input type="text" name="search" placeholder="Search my tasks..." value="@filter.Search" />

                        <select name="status">
                            <option value="">All Status</option>
                            <option value="Pending" selected="@(filter.Status == "Pending")">Pending</option>
                            <option value="InProgress" selected="@(filter.Status == "InProgress")">In Progress</option>
                            <option value="Completed" selected="@(filter.Status == "Completed")">Completed</option>
                        </select>

                        <select name="priority">
                            <option value="">All Priority</option>
                            <option value="Low" selected="@(filter.Priority == "Low")">Low</option>
                            <option value="Medium" selected="@(filter.Priority == "Medium")">Medium</option>
                            <option value="High" selected="@(filter.Priority == "High")">High</option>
                            <option value="Urgent" selected="@(filter.Priority == "Urgent")">Urgent</option>
                        </select>

                        <select name="categoryId">
                            <option value="">All Categories</option>
                            @foreach (var category in categories)
                            {
                                <option value="@category.Id" selected="@(filter.CategoryId == category.Id)">@category.Name</option>
                            }
                        </select>

                        <div class="filter-actions">
                            <button class="btn-primary" type="submit">Filter</button>
                            <a href="/User/MyTasks" class="btn-ghost">Clear</a>
                        </div>
                    </form>
                </section>

                <!-- Tasks Grid -->
                <section class="task-grid">
                    @if (tasks.Any())
                    {
                        foreach (var task in tasks)
                        {
                            var priorityClass = task.Priority.ToString().ToLower();
                            var statusClass = task.Status.ToString().ToLower();
                            var isOverdue = task.DueDate < DateTime.UtcNow && task.Status != TaskManagementSystem.Enums.TaskStatus.Completed;

                            <article class="task-card" data-task-id="@task.Id">
                                <div class="task-top">
                                    <span class="pill" style="background: rgba(59, 130, 246, 0.1); color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2);">
                                        @(task.CategoryName ?? "General")
                                    </span>
                                    <span class="pill @priorityClass">@task.Priority</span>
                                </div>

                                <h3>@task.Title</h3>
                                <p>@(task.Description?.Length > 85 ? task.Description.Substring(0, 85) + "..." : task.Description ?? "No description provided.")</p>

                                <div class="task-divider"></div>

                                <div class="task-meta">
                                    <span class="task-date @(isOverdue ? "overdue" : "")">
                                        <svg style="width:14px;height:14px;margin-right:4px" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                                        @(task.DueDate?.ToString("MMM dd, yyyy") ?? "No Due Date")
                                    </span>
                                    <span class="status @statusClass">@task.Status</span>
                                </div>

                                <a href="/User/TaskDetails/@task.Id" class="details-link">View Details →</a>
                            </article>
                        }
                    }
                    else
                    {
                        <div style="grid-column: 1 / -1; text-align: center; padding: 60px 20px; background: var(--bg-card); border-radius: 12px; border: 1px dashed var(--border);">
                            <p style="color: var(--text-muted); margin-bottom: 20px;">No tasks found matching your filters.</p>
                            <a href="/User/MyTasks" class="btn-primary">Reset Filters</a>
                        </div>
                    }
                </section>

                <!-- Pagination -->
                @if (tasks.Count > 0)
                {
                    <section class="pagination-row">
                        <button type="button">Previous</button>
                        <button class="active" type="button">1</button>
                        <button type="button">Next</button>
                    </section>
                }
            </div>
        </section>
    </div>

    <script>
        // Display today's date
        var todayDateElem = document.getElementById('todayDate');
        if (todayDateElem) {
            var now = new Date();
            todayDateElem.textContent = now.toLocaleDateString('en-US', {
                weekday: 'long', month: 'long', day: 'numeric', year: 'numeric'
            });
        }
    </script>
    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script src="~/js/User/mytasks.js" asp-append-version="true"></script>
</body>
</html>