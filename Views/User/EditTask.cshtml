@model TaskManagementSystem.DTOs.Task.UpdateTaskDto
@{
    Layout = null;
    ViewData["Title"] = "Edit Task";

    var taskId = ViewBag.TaskId;
    var categories = ViewBag.Categories as List<TaskManagementSystem.DTOs.Category.CategoryDto> ?? new List<TaskManagementSystem.DTOs.Category.CategoryDto>();
    var userName = ViewBag.UserName ?? "User";
    var userInitials = string.IsNullOrEmpty(userName) ? "U" :
        (userName.Split(' ').Length > 1 ?
         $"{userName.Split(' ')[0][0]}{userName.Split(' ')[1][0]}" :
         userName.Substring(0, 2).ToUpper());
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/createtask.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Dashboard</span></a>
                    <a href="/User/MyTasks" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">My Tasks</span></a>
                    <a href="/User/CreateTask" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">Create Task</span></a>
                    <a href="/User/Profile" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Profile</span></a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Logout" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg><span class="sidebar-text">Logout</span></a>
                </nav>
            </div>
            <div class="sidebar-bottom">
                <div class="profile-card">
                    <div class="avatar">@userInitials</div>
                    <div class="profile-info sidebar-text">
                        <strong>@userName</strong>
                        <span>@User.Identity?.Name</span>
                    </div>
                </div>
            </div>
            <button class="collapse-btn" id="collapseSidebar" type="button">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div><h1>Edit Task</h1><p>Modifying Task #@taskId</p></div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                    <div class="dropdown-wrap">
                        <button class="avatar-btn" id="avatarBtn" type="button">@userInitials</button>
                    </div>
                </div>
            </header>

            <div class="page-content create-page">
                <section class="create-grid">
                    <article class="card">
                        <h2>Update Task Details</h2>

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert-error" style="background:rgba(239,68,68,0.1); border:1px solid #ef4444; padding:10px; border-radius:8px; margin-bottom:15px; color:#ef4444;">
                                @TempData["Error"]
                            </div>
                        }

                        <form class="task-form" method="post" action="/User/EditTask/@taskId">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="AssignedToUserId" />

                            <label>Task Title *</label>
                            <input asp-for="Title" type="text" placeholder="Enter task title..." required />
                            <span asp-validation-for="Title" style="color:#ef4444; font-size:12px;"></span>

                            <label>Description</label>
                            <textarea asp-for="Description" id="taskDescription" rows="5" maxlength="500" placeholder="Update description..."></textarea>
                            <p class="char-counter" id="charCounter">0 / 500</p>

                            <div class="form-grid">
                                <label>
                                    Category
                                    <select asp-for="CategoryId">
                                        <option value="">Select category</option>
                                        @foreach (var category in categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </select>
                                </label>
                                <label>
                                    Priority
                                    <select asp-for="Priority">
                                        <option value="1">Low</option>
                                        <option value="2">Medium</option>
                                        <option value="3">High</option>
                                        <option value="4">Urgent</option>
                                    </select>
                                </label>
                            </div>

                            <div class="form-grid">
                                <label>
                                    Due Date
                                    <input asp-for="DueDate" type="date" />
                                </label>
                                <label>
                                    Current Status
                                    <select asp-for="Status">
                                        <option value="1">Pending</option>
                                        <option value="2">In Progress</option>
                                        <option value="3">Completed</option>
                                    </select>
                                </label>
                            </div>

                            <div class="form-actions">
                                <a class="btn-ghost" href="/User/TaskDetails/@taskId">Cancel</a>
                                <button class="btn-primary" type="submit">Save Changes</button>
                            </div>
                        </form>
                    </article>

                    <div class="side-stack">
                        <article class="card">
                            <h3>Editing Mode</h3>
                            <ul class="tip-list">
                                <li><span class="dot blue"></span>Changes are permanent after saving</li>
                                <li><span class="dot blue"></span>Ensure due dates are still valid</li>
                                <li><span class="dot blue"></span>Status updates will notify creators</li>
                            </ul>
                        </article>
                        <article class="card">
                            <h3>Status Meanings</h3>
                            <ul class="guide-list">
                                <li><span class="dot blue"></span><strong>Pending</strong><span>Not yet started</span></li>
                                <li><span class="dot amber"></span><strong>In Progress</strong><span>Currently active</span></li>
                                <li><span class="dot green"></span><strong>Completed</strong><span>Task is finished</span></li>
                            </ul>
                        </article>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script>
        const textarea = document.getElementById('taskDescription');
        const counter = document.getElementById('charCounter');
        if (textarea && counter) {
            counter.textContent = textarea.value.length + ' / 500';
            textarea.addEventListener('input', function() {
                counter.textContent = this.value.length + ' / 500';
            });
        }
    </script>
</body>
</html>