@model TaskManagementSystem.DTOs.User.UserProfileDto
@{
    Layout = null;
    ViewData["Title"] = "My Profile";

    var userName = Model?.FullName ?? "User";
    var userEmail = Model?.Email ?? "";
    var userRole = Model?.RoleName ?? "User";
    var memberSince = Model?.CreatedAt ?? DateTime.UtcNow;

    var userInitials = string.IsNullOrEmpty(userName) ? "U" :
        (userName.Split(' ').Length > 1 ?
         $"{userName.Split(' ')[0][0]}{userName.Split(' ')[1][0]}" :
         userName.Substring(0, 2).ToUpper());

    var totalTasks = ViewBag.TotalTasks ?? 0;
    var completedTasks = ViewBag.CompletedTasks ?? 0;
    var inProgressTasks = ViewBag.InProgressTasks ?? 0;
    var overdueTasks = ViewBag.OverdueTasks ?? 0;
    var completionRate = totalTasks > 0 ? (completedTasks * 100 / totalTasks) : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/profile.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Dashboard</span></a>
                    <a href="/User/MyTasks" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">My Tasks</span></a>
                    <a href="/User/CreateTask" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">Create Task</span></a>
                    <a href="/User/Profile" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Profile</span></a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Logout" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg><span class="sidebar-text">Logout</span></a>
                </nav>
            </div>
            <div class="sidebar-bottom">
                <div class="profile-card">
                    <div class="avatar">@userInitials</div>
                    <div class="profile-info sidebar-text">
                        <strong>@userName</strong>
                        <span>@userEmail</span>
                    </div>
                </div>
            </div>
            <button class="collapse-btn" id="collapseSidebar" type="button">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div><h1>My Profile</h1><p id="todayDate"></p></div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                    <div class="dropdown-wrap">
                        <button class="avatar-btn" id="avatarBtn" type="button">@userInitials</button>
                        <div class="dropdown-menu profile-menu" id="profileMenu">
                            <a href="/User/Profile">My Profile</a>
                            <a href="/Auth/Logout">Logout</a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="page-content profile-page">
                @if (TempData["Success"] != null)
                {
                    <div style="background:rgba(34,197,94,0.1); border:1px solid #22c55e; padding:10px; border-radius:8px; margin-bottom:15px; color:#22c55e;">
                        @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div style="background:rgba(239,68,68,0.1); border:1px solid #ef4444; padding:10px; border-radius:8px; margin-bottom:15px; color:#ef4444;">
                        @TempData["Error"]
                    </div>
                }

                <section class="profile-grid">
                    <div class="left-column">
                        <article class="card">
                            <h2>Personal Information</h2>
                            <div class="profile-avatar-wrap">
                                <div class="big-avatar">@userInitials</div>
                            </div>
                            <form class="profile-form" method="post" action="/User/UpdateProfile">
                                @Html.AntiForgeryToken()
                                <label>Full Name</label>
                                <input type="text" name="FullName" value="@userName" required />
                                <label>Email</label>
                                <input type="email" value="@userEmail" disabled />
                                <p class="muted-note">Email cannot be changed. Contact admin.</p>
                                <button class="btn-primary" type="submit">Update Info</button>
                            </form>
                        </article>

                        <article class="card">
                            <div class="card-head">
                                <h2>Change Password</h2>
                            </div>
                            <form class="profile-form" method="post" action="/User/ChangePassword">
                                @Html.AntiForgeryToken()
                                <label>Current Password</label>
                                <input type="password" name="CurrentPassword" required />

                                <label>New Password</label>
                                <input type="password" name="NewPassword" required minlength="6" />

                                <label>Confirm Password</label>
                                <input type="password" name="ConfirmPassword" required />

                                <button class="btn-primary" type="submit">Update Password</button>
                            </form>
                        </article>
                    </div>

                    <div class="right-column">
                        <article class="card">
                            <h3>My Activity</h3>
                            <div class="stats-grid">
                                <div class="mini-stat"><span>Tasks Assigned</span><strong>@totalTasks</strong></div>
                                <div class="mini-stat"><span>Completed</span><strong>@completedTasks</strong></div>
                                <div class="mini-stat"><span>In Progress</span><strong>@inProgressTasks</strong></div>
                                <div class="mini-stat"><span>Overdue</span><strong>@overdueTasks</strong></div>
                            </div>
                            <div class="completion-row"><span>Overall Completion Rate</span><strong>@completionRate%</strong></div>
                            <div class="completion-bar">
                                <div class="completion-fill" style="width: @completionRate%;"></div>
                            </div>
                        </article>

                        <article class="card">
                            <h3>Account Details</h3>
                            <div class="detail-list">
                                <p><span>Role:</span><strong>@userRole</strong></p>
                                <p><span>Member Since:</span><strong>@memberSince.ToString("MMMM yyyy")</strong></p>
                                <p><span>Account Status:</span><strong class="status completed">Active</strong></p>
                            </div>
                        </article>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script src="~/js/User/profile.js" asp-append-version="true"></script>
</body>
</html>