@{
    Layout = null;
    ViewData["Title"] = "My Profile";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/profile.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard"><span class="brand-icon">✓</span><span class="brand-text sidebar-text">TaskFlow</span></a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Dashboard</span></a>
                    <a href="/User/MyTasks" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">My Tasks</span></a>
                    <a href="/User/CreateTask" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg><span class="sidebar-text">Create Task</span></a>
                    <a href="/User/Profile" class="nav-item active"><svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg><span class="sidebar-text">Profile</span></a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Login" class="nav-item"><svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg><span class="sidebar-text">Logout</span></a>
                </nav>
            </div>
            <div class="sidebar-bottom"><div class="profile-card"><div class="avatar">JD</div><div class="profile-info sidebar-text"><strong>John Doe</strong><span>john@email.com</span></div></div></div>
            <button class="collapse-btn" id="collapseSidebar" type="button" aria-label="Toggle sidebar">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div><h1>My Profile</h1><p id="todayDate"></p></div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button">☰</button>
                    <div class="search-wrap"><input type="text" placeholder="Search tasks..." /></div>
                    <div class="dropdown-wrap"><button class="icon-btn" id="notifBtn" type="button"><svg viewBox="0 0 24 24" fill="none"><path d="M15 17h5l-1.4-1.4a2 2 0 0 1-.6-1.4V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5m6 0a3 3 0 1 1-6 0h6Z" stroke="currentColor" stroke-width="1.8" /></svg><span class="dot-badge">2</span></button><div class="dropdown-menu" id="notifMenu"><p>2 recent activity updates.</p><p>Password reminder available.</p></div></div>
                    <div class="dropdown-wrap"><button class="avatar-btn" id="avatarBtn" type="button">JD</button><div class="dropdown-menu profile-menu" id="profileMenu"><a href="/User/Profile">My Profile</a><a href="/Auth/Login">Logout</a></div></div>
                </div>
            </header>

            <div class="page-content profile-page">
                <section class="profile-grid">
                    <div class="left-column">
                        <article class="card">
                            <h2>Personal Information</h2>
                            <div class="profile-avatar-wrap">
                                <div class="big-avatar">JD</div>
                                <a href="#">Change Photo</a>
                            </div>
                            <form class="profile-form">
                                <label>Full Name<input type="text" value="John Doe" /></label>
                                <label>Email<input type="text" value="john@email.com" disabled /></label>
                                <p class="muted-note">Email cannot be changed. Contact admin.</p>
                                <button class="btn-primary" type="submit">Update Info</button>
                            </form>
                        </article>

                        <article class="card">
                            <div class="card-head">
                                <h2>Change Password</h2>
                                <div class="section-tabs">
                                    <button class="tab-btn active" data-tab="passwordSection" type="button">Password</button>
                                    <button class="tab-btn" data-tab="passwordSection" type="button">Security</button>
                                </div>
                            </div>
                            <form class="profile-form section-panel active" id="passwordSection">
                                <label>Current Password
                                    <div class="password-wrap">
                                        <input type="password" id="currentPassword" />
                                        <button type="button" class="toggle-pass" data-target="currentPassword">Show</button>
                                    </div>
                                </label>
                                <label>New Password
                                    <div class="password-wrap">
                                        <input type="password" id="newPassword" />
                                        <button type="button" class="toggle-pass" data-target="newPassword">Show</button>
                                    </div>
                                </label>
                                <div class="strength-wrap"><span>Strength: Medium</span><div class="strength-bar"><div class="strength-fill"></div></div></div>
                                <label>Confirm Password
                                    <div class="password-wrap">
                                        <input type="password" id="confirmPassword" />
                                        <button type="button" class="toggle-pass" data-target="confirmPassword">Show</button>
                                    </div>
                                </label>
                                <button class="btn-primary" type="submit">Update Password</button>
                            </form>
                        </article>
                    </div>

                    <div class="right-column">
                        <article class="card">
                            <h3>My Activity</h3>
                            <div class="stats-grid">
                                <div class="mini-stat"><span>Tasks Assigned</span><strong>23</strong></div>
                                <div class="mini-stat"><span>Completed</span><strong>14</strong></div>
                                <div class="mini-stat"><span>In Progress</span><strong>6</strong></div>
                                <div class="mini-stat"><span>Overdue</span><strong>3</strong></div>
                            </div>
                            <div class="completion-row"><span>Overall Completion Rate</span><strong>60%</strong></div>
                            <div class="completion-bar"><div class="completion-fill"></div></div>
                        </article>

                        <article class="card">
                            <h3>Account Details</h3>
                            <div class="detail-list">
                                <p><span>Role:</span><strong>User</strong></p>
                                <p><span>Member Since:</span><strong>January 2025</strong></p>
                                <p><span>Last Login:</span><strong>April 29, 2026</strong></p>
                                <p><span>Account Status:</span><strong class="status completed">Active</strong></p>
                                <p><span>Tasks This Month:</span><strong>5</strong></p>
                            </div>
                        </article>

                        <article class="card">
                            <h3>Recent Activity</h3>
                            <ul class="activity-list">
                                <li><span class="dot green"></span><div><p>Completed "Setup EF Core models"</p><small>1 hour ago</small></div></li>
                                <li><span class="dot blue"></span><div><p>Updated "Design login page"</p><small>Yesterday</small></div></li>
                                <li><span class="dot amber"></span><div><p>Due date approaching: "JWT auth"</p><small>Yesterday</small></div></li>
                                <li><span class="dot red"></span><div><p>Overdue: "Fix login redirect bug"</p><small>2 days ago</small></div></li>
                            </ul>
                        </article>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script src="~/js/User/profile.js" asp-append-version="true"></script>
</body>
</html>
