@model IEnumerable<TaskManagementSystem.DTOs.Task.TaskDto>
@{
    Layout = null;
    ViewData["Title"] = "My Dashboard";

    // Calculate statistics from real data
    var taskList = Model?.ToList() ?? new List<TaskManagementSystem.DTOs.Task.TaskDto>();
    var totalTasks = taskList.Count;
    var completedTasks = taskList.Count(t => t.Status == TaskManagementSystem.Enums.TaskStatus.Completed);
    var inProgressTasks = taskList.Count(t => t.Status == TaskManagementSystem.Enums.TaskStatus.InProgress);
    var pendingTasks = taskList.Count(t => t.Status == TaskManagementSystem.Enums.TaskStatus.Pending);
    var overdueTasks = taskList.Count(t => t.DueDate < DateTime.UtcNow && t.Status != TaskManagementSystem.Enums.TaskStatus.Completed);

    var completedPercent = totalTasks > 0 ? (completedTasks * 100 / totalTasks) : 0;
    var inProgressPercent = totalTasks > 0 ? (inProgressTasks * 100 / totalTasks) : 0;
    var pendingPercent = totalTasks > 0 ? (pendingTasks * 100 / totalTasks) : 0;
    var overduePercent = totalTasks > 0 ? (overdueTasks * 100 / totalTasks) : 0;

    var userName = ViewBag.UserName ?? "User";
    var userInitials = string.IsNullOrEmpty(userName) ? "U" :
        (userName.Split(' ').Length > 1 ?
         $"{userName.Split(' ')[0][0]}{userName.Split(' ')[1][0]}" :
         userName.Substring(0, 2).ToUpper());

    // Get recent tasks (last 5)
    var recentTasks = taskList.OrderByDescending(t => t.CreatedAt).Take(5).ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskFlow</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/User/dashboard.css" asp-append-version="true" />
</head>
<body class="user-body">
    <div class="user-wrapper" id="userWrapper">
        <aside class="user-sidebar" id="userSidebar">
            <div class="sidebar-top">
                <a class="brand" href="/User/Dashboard">
                    <span class="brand-icon">✓</span>
                    <span class="brand-text sidebar-text">TaskFlow</span>
                </a>
                <p class="panel-label sidebar-text">My Workspace</p>
                <div class="sidebar-divider"></div>
                <nav class="side-nav" id="sideNav">
                    <a href="/User/Dashboard" class="nav-item active">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M3 13h8V3H3v10Zm10 8h8V11h-8v10ZM3 21h8v-6H3v6Zm10-10h8V3h-8v8Z" stroke="currentColor" stroke-width="1.8" /></svg>
                        <span class="sidebar-text">Dashboard</span>
                    </a>
                    <a href="/User/MyTasks" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                        <span class="sidebar-text">My Tasks</span>
                    </a>
                    <a href="/User/CreateTask" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M12 5v14m-7-7h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
                        <span class="sidebar-text">Create Task</span>
                    </a>
                    <a href="/User/Profile" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M16 7a4 4 0 1 1-8 0 4 4 0 0 1 8 0Zm5 13v-1a5 5 0 0 0-5-5H8a5 5 0 0 0-5 5v1" stroke="currentColor" stroke-width="1.8" /></svg>
                        <span class="sidebar-text">Profile</span>
                    </a>
                    <div class="sidebar-divider"></div>
                    <a href="/Auth/Logout" class="nav-item">
                        <svg viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4m7 14 5-5-5-5m5 5H9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        <span class="sidebar-text">Logout</span>
                    </a>
                </nav>
            </div>
            <div class="sidebar-bottom">
                <div class="profile-card">
                    <div class="avatar">@userInitials</div>
                    <div class="profile-info sidebar-text">
                        <strong>@userName</strong>
                        <span>@User.Identity?.Name</span>
                    </div>
                </div>
            </div>
            <button class="collapse-btn" id="collapseSidebar" type="button" aria-label="Toggle sidebar">❮</button>
        </aside>

        <section class="user-main">
            <header class="topbar">
                <div>
                    <h1>My Dashboard</h1>
                    <p id="todayDate"></p>
                </div>
                <div class="topbar-actions">
                    <button class="hamburger-btn" id="mobileMenuBtn" type="button" aria-label="Open menu">☰</button>
                    <div class="dropdown-wrap">
                        <button class="avatar-btn" id="avatarBtn" type="button">@userInitials</button>
                        <div class="dropdown-menu profile-menu" id="profileMenu">
                            <a href="/User/Profile">My Profile</a>
                            <a href="/Auth/Logout">Logout</a>
                        </div>
                    </div>
                </div>
            </header>

            <div class="page-content">
                <!-- Stats Cards with Real Data -->
                <section class="stats-grid">
                    <article class="card stat-card">
                        <div class="stat-top"><span>My Tasks</span></div>
                        <h3>@totalTasks</h3>
                        <div class="progress"><span style="width:100%; background:#3b82f6;"></span></div>
                        <small>Total assigned to you</small>
                    </article>
                    <article class="card stat-card">
                        <div class="stat-top"><span>Completed</span></div>
                        <h3>@completedTasks</h3>
                        <div class="progress"><span style="width:@completedPercent%; background:#22c55e;"></span></div>
                        <small>@completedPercent% of total</small>
                    </article>
                    <article class="card stat-card">
                        <div class="stat-top"><span>In Progress</span></div>
                        <h3>@inProgressTasks</h3>
                        <div class="progress"><span style="width:@inProgressPercent%; background:#f59e0b;"></span></div>
                        <small>Currently working on</small>
                    </article>
                    <article class="card stat-card">
                        <div class="stat-top"><span>Overdue</span></div>
                        <h3>@overdueTasks</h3>
                        <div class="progress"><span style="width:@Math.Min(overduePercent, 100)%; background:#ef4444;"></span></div>
                        <small>Needs your attention</small>
                    </article>
                </section>

                <!-- Tasks by Status Bars -->
                <section class="content-grid">
                    <article class="card">
                        <h2>My Tasks by Status</h2>
                        <div class="status-bars">
                            <div class="bar-row">
                                <span>Pending</span>
                                <div class="bar-track"><div class="bar-fill blue" style="width:@pendingPercent%"></div></div>
                                <strong>@pendingTasks</strong>
                            </div>
                            <div class="bar-row">
                                <span>In Progress</span>
                                <div class="bar-track"><div class="bar-fill amber" style="width:@inProgressPercent%"></div></div>
                                <strong>@inProgressTasks</strong>
                            </div>
                            <div class="bar-row">
                                <span>Completed</span>
                                <div class="bar-track"><div class="bar-fill green" style="width:@completedPercent%"></div></div>
                                <strong>@completedTasks</strong>
                            </div>
                            <div class="bar-row">
                                <span>Overdue</span>
                                <div class="bar-track"><div class="bar-fill red" style="width:@Math.Min(overduePercent, 100)%"></div></div>
                                <strong>@overdueTasks</strong>
                            </div>
                        </div>
                    </article>

                    <!-- Upcoming Deadlines -->
                    <article class="card">
                        <h2>Upcoming Deadlines</h2>
                        <ul class="deadline-list">
                            @if (taskList.Where(t => t.DueDate.HasValue && t.Status != TaskManagementSystem.Enums.TaskStatus.Completed).OrderBy(t => t.DueDate).Take(5).Any())
                            {
                                foreach (var task in taskList.Where(t => t.DueDate.HasValue && t.Status != TaskManagementSystem.Enums.TaskStatus.Completed).OrderBy(t => t.DueDate).Take(5))
                                {
                                    var daysUntilDue = (task.DueDate.Value - DateTime.UtcNow).Days;
                                    var priorityClass = task.Priority.ToString().ToLower();
                                    <li>
                                        <span class="priority-dot @priorityClass"></span>
                                        <strong>@task.Title</strong>
                                        <span class="muted">Due @task.DueDate.Value.ToString("MMM dd")</span>
                                        <span class="status @(daysUntilDue < 0 ? "overdue" : task.Status.ToString().ToLower().Replace(" ", ""))">
                                            @(daysUntilDue < 0 ? "Overdue" : task.Status)
                                        </span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li>No upcoming deadlines. Great job!</li>
                            }
                        </ul>
                    </article>
                </section>

                <!-- Recent Tasks Table -->
                <section class="card table-card">
                    <div class="card-title-row">
                        <h2>My Recent Tasks</h2>
                        <a href="/User/MyTasks">View All &rarr;</a>
                    </div>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>Task Name</th>
                                    <th>Category</th>
                                    <th>Priority</th>
                                    <th>Due Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentTasks.Any())
                                {
                                    foreach (var task in recentTasks)
                                    {
                                        var priorityClass = task.Priority.ToString().ToLower();
                                        var statusClass = task.Status.ToString().ToLower().Replace(" ", "");
                                        <tr>
                                            <td>@task.Title</td>
                                            <td><span class="pill">@(task.CategoryName ?? "Uncategorized")</span></td>
                                            <td><span class="pill @priorityClass">@task.Priority</span></td>
                                            <td>@(task.DueDate?.ToString("MMM dd") ?? "No date")</td>
                                            <td><span class="status @statusClass">@task.Status</span></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align:center;">No tasks assigned to you yet.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>
        </section>
    </div>

    <script>
        // Display today's date
        document.getElementById('todayDate').textContent = new Date().toLocaleDateString('en-US', {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });
    </script>
    <script src="~/js/User/user-layout.js" asp-append-version="true"></script>
    <script src="~/js/User/dashboard.js" asp-append-version="true"></script>
</body>
</html>